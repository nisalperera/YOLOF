{
  "name": "YOLOF",
  "build": {
    "context": "${localWorkspaceFolder}",
    "dockerfile": "${localWorkspaceFolder}/docker/Dockerfile",
    "args": {
      // "UID": "${localEnv:USER_ID}",
      // "GID": "${localEnv:GROUP_ID}",
      "USER": "${localEnv:USER:ubuntu}"
    }
  },
  "workspaceFolder": "/home/${localEnv:USER}/YOLOF",
  "remoteUser": "${localEnv:USER}",
  "updateRemoteUserUID": false,
  "containerEnv": {
    "HOME": "/home/${localEnv:USER}",
    // "USER": "${localEnv:USER}"
  },
  "runArgs": [
    "--network=host",
    "--ipc=host",
    "--gpus=all",
    "--env-file=${localWorkspaceFolder}/.env",
    "--name=YOLOF"
  ],
  "mounts": [
    "source=${localEnv:HOME}/Projects/personal/data/coco2017/,target=/home/${localEnv:USER:ubuntu}/YOLOF/datasets/coco/,type=bind",
    "source=${localWorkspaceFolder}/output/,target=/home/${localEnv:USER:ubuntu}/YOLOF/output/,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.debugpy",
        "njpwerner.autodocstring"
      ]
    }
  },
  "remoteEnv": {
    "DOCKER_BUILDKIT": "1"
  }
}